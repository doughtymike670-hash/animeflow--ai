          <div class="upload-zone" id="videoUploadZone">
            <input type="file" id="videoFileInput" accept="video/*" onchange="handleVideoUpload(event)">
            <div class="upload-icon">🎬</div>
            <h3>Drop your anime video here</h3>
            <p>MP4, MOV, AVI supported — Generated from Hailuo AI</p>
          </div>
          <div class="progress-wrap" id="videoProgress">
            <div class="progress-label" id="videoProgressLabel">Uploading...</div>
            <div class="progress-bar-bg"><div class="progress-bar-fill" id="videoProgressFill"></div></div>
          </div>
        </div>
        <div class="card">
          <div class="card-header"><div class="card-title">🎬 My Videos</div><span class="badge badge-green" id="videoCount">0 videos</span></div>
          <div class="video-grid" id="videoList"><div style="text-align:center;padding:30px;color:var(--text-dim);font-size:13px;grid-column:1/-1">No videos yet. Generate from Hailuo AI and upload here!</div></div>
        </div>
      </div>

      <!-- SCHEDULE PAGE -->
      <div class="page" id="page-schedule">
        <div class="card" style="margin-bottom:16px">
          <div class="card-header"><div class="card-title">📅 Create Campaign</div><span class="badge badge-purple">7 Day Plan</span></div>
          <div class="campaign-form">
            <div class="form-row">
              <div class="form-group" style="margin:0">
                <label class="form-label">Campaign Name</label>
                <input type="text" class="form-input" id="campName" placeholder="e.g. Summer Vibes Campaign">
              </div>
              <div class="form-group" style="margin:0">
                <label class="form-label">Anime Mode</label>
                <select class="select-input" id="campMode">
                  <option value="singer">Anime Singer</option>
                  <option value="mv">Music Video</option>
                  <option value="avatar">My Anime Avatar</option>
                </select>
              </div>
