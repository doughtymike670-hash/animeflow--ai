            <div class="form-row">
              <div class="form-group" style="margin:0">
                <label class="form-label">Long Video Time</label>
                <input type="time" class="form-input" id="campVideoTime" value="20:00">
              </div>
              <div class="form-group" style="margin:0">
                <label class="form-label">Short Video Time</label>
                <input type="time" class="form-input" id="campShortTime" value="12:00">
              </div>
            </div>
            <button class="btn btn-primary btn-full" onclick="createCampaign()">📅 Create 7 Day Campaign</button>
          </div>
        </div>
        <div class="card" id="campaignCalendar" style="display:none">
          <div class="card-header"><div class="card-title">📅 Weekly Schedule</div><span class="badge badge-green">Active</span></div>
          <div class="days-grid" id="daysGrid"></div>
        </div>
        <div class="card" style="margin-top:16px">
          <div class="card-header"><div class="card-title">📋 My Campaigns</div></div>
          <div id="campaignList"><div style="text-align:center;padding:20px;color:var(--text-dim);font-size:13px">No campaigns yet</div></div>
        </div>
      </div>

      <!-- AUTO POST PAGE -->
      <div class="page" id="page-autopost">
        <div class="card" style="margin-bottom:16px">
          <div class="card-header"><div class="card-title">🤖 Make.com Auto Post Setup</div><span class="badge badge-cyan">Step by Step</span></div>
          <div style="display:flex;flex-direction:column;gap:16px">
            <div style="background:var(--panel);border-radius:10px;padding:16px;border:1px solid var(--border)">
              <div style="font-size:13px;font-weight:600;margin-bottom:8px;color:var(--purple)">Step 1 — Open Make.com</div>
              <div style="font-size:12px;color:var(--text-dim);line-height:1.7">Go to <strong style="color:var(--cyan)">make.com</strong> → Click "+" → Create new scenario</div>
            </div>
            <div style="background:var(--panel);border-radius:10px;padding:16px;border:1px solid var(--border)">
              <div style="font-size:13px;font-weight:600;margin-bottom:8px;color:var(--purple)">Step 2 — Add Supabase Trigger</div>
              <div style="font-size:12px;color:var(--text-dim);line-height:1.7">Search "Supabase" → Select "Watch Rows" → Connect with your URL and key → Select table: <strong style="color:var(--cyan)">audio_uploads</strong></div>
            </div>
            <div style="background:var(--panel);border-radius:10px;padding:16px;border:1px solid var(--border)">
              <div style="font-size:13px;font-weight:600;margin-bottom:8px;color:var(--purple)">Step 3 — Connect Social Media</div>
              <div style="font-size:12px;color:var(--text-dim);line-height:1.7">Add Instagram → Connect account → Add TikTok → Connect account → Add YouTube → Connect channel</div>
            </div>
            <div style="background:var(--panel);border-radius:10px;padding:16px;border:1px solid var(--border)">
              <div style="font-size:13px;font-weight:600;margin-bottom:8px;color:var(--purple)">Step 4 — Your Supabase Connection Details</div>
              <div style="font-size:12px;color:var(--text-dim);margin-bottom:8px">Use these to connect Make.com to your Supabase:</div>
              <div style="font-size:11px;background:var(--card);padding:10px;border-radius:8px;border:1px solid var(--border)">
                <div style="color:var(--text-dim);margin-bottom:4px">Supabase URL:</div>
                <div style="color:var(--cyan);word-break:break-all;margin-bottom:10px">https://cifxgwlynrrgujzrhasr.supabase.co</div>
                <div style="color:var(--text-dim);margin-bottom:4px">Table to watch:</div>
                <div style="color:var(--cyan)">audio_uploads</div>
              </div>
            </div>
            <div style="background:var(--panel);border-radius:10px;padding:16px;border:1px solid var(--border)">
              <div style="font-size:13px;font-weight:600;margin-bottom:8px;color:var(--green)">Step 5 — Turn it ON</div>
              <div style="font-size:12px;color:var(--text-dim);line-height:1.7">Toggle your Make.com scenario ON. From now on every video you upload here will automatically post to all your social media at your scheduled times.</div>
            </div>
          </div>
        </div>
        <div class="card">
          <div class="card-header"><div class="card-title">✅ Connection Status</div></div>
          <div style="display:flex;flex-direction:column;gap:10px;margin-top:4px">
            <div style="display:flex;align-items:center;justify-content:space-between;padding:12px;background:var(--panel);border-radius:10px;border:1px solid var(--border)">
              <div style="display:flex;align-items:center;gap:10px"><span style="font-size:20px">🗄️</span><div><div style="font-size:12px;font-weight:600">Supabase</div><div style="font-size:10px;color:var(--text-dim)">Database & Storage</div></div></div>
              <span class="badge badge-green">● Connected</span>
            </div>
            <div style="display:flex;align-items:center;justify-content:space-between;padding:12px;background:var(--panel);border-radius:10px;border:1px solid var(--border)">
              <div style="display:flex;align-items:center;gap:10px"><span style="font-size:20px">🤖</span><div><div style="font-size:12px;font-weight:600">Claude AI</div><div style="font-size:10px;color:var(--text-dim)">Audio enhancement & prompts</div></div></div>
              <span class="badge badge-green">● Connected</span>
            </div>
            <div style="display:flex;align-items:center;justify-content:space-between;padding:12px;background:var(--panel);border-radius:10px;border:1px solid var(--border)">
              <div style="display:flex;align-items:center;gap:10px"><span style="font-size:20px">🔗</span><div><div style="font-size:12px;font-weight:600">Make.com</div><div style="font-size:10px;color:var(--text-dim)">Auto posting automation</div></div></div>
              <span class="badge badge-gold">⚠ Setup Required</span>
            </div>
            <div style="display:flex;align-items:center;justify-content:space-between;padding:12px;background:var(--panel);border-radius:10px;border:1px solid var(--border)">
              <div style="display:flex;align-items:center;gap:10px"><span style="font-size:20px">🎬</span><div><div style="font-size:12px;font-weight:600">Hailuo AI</div><div style="font-size:10px;color:var(--text-dim)">Anime video generation</div></div></div>
              <span class="badge badge-cyan">Manual Mode</span>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
// ── CONFIG ──
const SUPABASE_URL = 'https://cifxgwlynrrgujzrhasr.supabase.co';
const SUPABASE_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImNpZnhnd2x5bnJyZ3VqenJoYXNyIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODIzNTg4MzcsImV4cCI6MjA5NzkzNDgzN30.iVx_GWZaAF9S2rTW1SDNCKgw4msZNG4CPc7oxQUzz0Y';
const ANTHROPIC_KEY = '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';

const sb = supabase.createClient(SUPABASE_URL, SUPABASE_KEY);
let currentUser = null;

// ── AUTH ──
async function handleLogin() {
  const email = document.getElementById('loginEmail').value;
  const password = document.getElementById('loginPassword').value;
  if (!email || !password) return showAuthError('Please fill in all fields');
  const btn = event.target;
  btn.disabled = true;
  btn.innerHTML = '<span class="loader"></span> Logging in...';
  const { data, error } = await sb.auth.signInWithPassword({ email, password });
  btn.disabled = false;
  btn.textContent = 'Login to Studio';
  if (error) return showAuthError(error.message);
  currentUser = data.user;
  showApp();
}

async function handleSignup() {
  const name = document.getElementById('signupName').value;
  const email = document.getElementById('signupEmail').value;
  const password = document.getElementById('signupPassword').value;
  if (!name || !email || !password) return showAuthError('Please fill in all fields');
  if (password.length < 6) return showAuthError('Password must be at least 6 characters');
  const btn = event.target;
  btn.disabled = true;
  btn.innerHTML = '<span class="loader"></span> Creating account...';
  const { data, error } = await sb.auth.signUp({ email, password, options: { data: { full_name: name } } });
  btn.disabled = false;
  btn.textContent = 'Create Account';
  if (error) return showAuthError(error.message);
  showAuthSuccess('Account created! Please check your email to confirm, then login.');
}

async function handleLogout() {
  await sb.auth.signOut();
  document.getElementById('appWrap').style.display = 'none';
  document.getElementById('authWrap').style.display = 'flex';
  currentUser = null;
}

function showAuthError(msg) {
  const el = document.getElementById('authError');
  el.textContent = '⚠ ' + msg;
  el.style.display = 'block';
  setTimeout(() => el.style.display = 'none', 4000);
}

function showAuthSuccess(msg) {
  const el = document.getElementById('authSuccess');
  el.textContent = '✅ ' + msg;
  el.style.display = 'block';
}

function switchTab(tab) {
  document.querySelectorAll('.auth-tab').forEach((t,i) => t.classList.toggle('active', (tab==='login'&&i===0)||(tab==='signup'&&i===1)));
  document.getElementById('loginForm').style.display = tab === 'login' ? 'block' : 'none';
  document.getElementById('signupForm').style.display = tab === 'signup' ? 'block' : 'none';
  document.getElementById('authError').style.display = 'none';
  document.getElementById('authSuccess').style.display = 'none';
}

// ── APP INIT ──
async function showApp() {
  document.getElementById('authWrap').style.display = 'none';
  const app = document.getElementById('appWrap');
  app.style.display = 'flex';
  const { data: { user } } = await sb.auth.getUser();
  if (user) {
    currentUser = user;
    const name = user.user_metadata?.full_name || user.email.split('@')[0];
    document.getElementById('sidebarUserName').textContent = name;
  }
  loadStats();
  loadAudioList();
  loadVideoList();
  loadCampaignList();
}

sb.auth.onAuthStateChange((event, session) => {
  if (session?.user) { currentUser = session.user; showApp(); }
});

// ── NAVIGATION ──
function showPage(page) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  document.getElementById('page-' + page).classList.add('active');
  document.querySelectorAll('.nav-item').forEach(n => { if (n.textContent.trim().toLowerCase().includes(page) || n.getAttribute('onclick')?.includes(page)) n.classList.add('active'); });
  const titles = { dashboard: ['Dashboard', 'Welcome back'], audio: ['Audio Studio', 'Upload and enhance your music'], prompts: ['Anime Prompts', 'Generate 7 day content prompts'], videos: ['My Videos', 'Manage your anime videos'], schedule: ['Schedule', 'Plan your 7 day campaign'], autopost: ['Auto Post', 'Connect Make.com for automation'] };
  document.getElementById('pageTitle').textContent = titles[page][0];
  document.getElementById('pageSubtitle').textContent = titles[page][1];
}

// ── STATS ──
async function loadStats() {
  if (!currentUser) return;
  const [audio, prompts, videos, campaigns] = await Promise.all([
    sb.from('audio_uploads').select('id', { count: 'exact' }).eq('user_id', currentUser.id),
    sb.from('audio_uploads').select('id', { count: 'exact' }).eq('user_id', currentUser.id),
    sb.from('audio_uploads').select('id', { count: 'exact' }).eq('user_id', currentUser.id),
    sb.from('campaigns').select('id', { count: 'exact' }).eq('user_id', currentUser.id)
  ]);
  document.getElementById('statAudio').textContent = audio.count || 0;
  document.getElementById('statPrompts').textContent = (audio.count || 0) * 7;
  document.getElementById('statVideos').textContent = audio.count || 0;
  document.getElementById('statCampaigns').textContent = campaigns.count || 0;
}

// ── AUDIO UPLOAD ──
async function handleAudioUpload(event) {
  const file = event.target.files[0];
  if (!file || !currentUser) return;
  const progress = document.getElementById('audioProgress');
  const fill = document.getElementById('audioProgressFill');
  const label = document.getElementById('audioProgressLabel');
  progress.style.display = 'block';
  label.textContent = 'Uploading to Supabase...';
  fill.style.width = '30%';
  const fileName = `${currentUser.id}/${Date.now()}_${file.name}`;
  const { data: uploadData, error: uploadError } = await sb.storage.from('audio-files').upload(fileName, file);
  if (uploadError) { showToast('Upload failed: ' + uploadError.message, 'error'); progress.style.display = 'none'; return; }
  fill.style.width = '60%';
  label.textContent = 'Saving to database...';
  const { data: urlData } = sb.storage.from('audio-files').getPublicUrl(fileName);
  const { error: dbError } = await sb.from('audio_uploads').insert({ user_id: currentUser.id, file_name: file.name, file_url: urlData.publicUrl, duration: 0, quality_score: 0 });
  if (dbError) { showToast('Database error: ' + dbError.message, 'error'); progress.style.display = 'none'; return; }
  fill.style.width = '80%';
  label.textContent = '🤖 AI analyzing your audio...';
  const aiProcessing = document.getElementById('aiProcessing');
  aiProcessing.style.display = 'block';
  await analyzeWithAI(file.name);
  fill.style.width = '100%';
  label.textContent = '✅ Upload complete!';
  setTimeout(() => { progress.style.display = 'none'; }, 2000);
  showToast('✅ Audio uploaded and saved!', 'success');
  loadAudioList();
  loadStats();
}

async function analyzeWithAI(fileName) {
  try {
    const response = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'x-api-key': ANTHROPIC_KEY, 'anthropic-version': '2023-06-01', 'anthropic-dangerous-direct-browser-access': 'true' },
      body: JSON.stringify({
        model: 'claude-sonnet-4-6',
        max_tokens: 1000,
        messages: [{ role: 'user', content: `You are a professional music producer. Analyze this audio file named "${fileName}" and provide studio enhancement recommendations. Give specific settings for: EQ (which frequencies to boost/cut), Compression (threshold, ratio, attack, release), Reverb (type and amount), Vocal clarity enhancement. Also give a quality score out of 100. Keep response concise and professional.` }]
      })
    });
    const data = await response.json();
    const result = data.content?.[0]?.text || 'Analysis complete. Standard enhancement applied.';
    const resultEl = document.getElementById('aiAnalysisResult');
    resultEl.textContent = result;
    resultEl.style.display = 'block';
  } catch(e) {
    const resultEl = document.getElementById('aiAnalysisResult');
    resultEl.textContent = '⚠ AI analysis requires API key. Add your Anthropic API key to the code to enable this feature.';
    resultEl.style.display = 'block';
  }
}

// ── LOAD AUDIO LIST ──
async function loadAudioList() {
  if (!currentUser) return;
  const { data, error } = await sb.from('audio_uploads').select('*').eq('user_id', currentUser.id).order('created_at', { ascending: false });
  const list = document.getElementById('audioList');
  const count = document.getElementById('audioCount');
  if (!data || data.length === 0) { list.innerHTML = '<div style="text-align:center;padding:30px;color:var(--text-dim);font-size:13px">No audio uploaded yet. Upload your first track above!</div>'; count.textContent = '0 tracks'; return; }
  count.textContent = data.length + ' track' + (data.length !== 1 ? 's' : '');
  list.innerHTML = data.map(track => `
    <div class="audio-item">
      <div class="audio-item-icon">🎵</div>
      <div class="audio-item-info">
        <div class="audio-item-name">${track.file_name}</div>
        <div class="audio-item-meta">Uploaded ${new Date(track.created_at).toLocaleDateString()}</div>
      </div>
      <div class="audio-item-actions">
        <button class="btn btn-ghost" style="font-size:11px;padding:6px 12px" onclick="window.open('${track.file_url}')">▶ Play</button>
        <button class="btn btn-cyan" style="font-size:11px;padding:6px 12px" onclick="showPage('prompts')">🎌 Prompts</button>
      </div>
    </div>`).join('');
}

// ── GENERATE PROMPTS ──
async function generatePrompts() {
  const style = document.getElementById('animeStyle').value;
  const mode = document.getElementById('contentMode').value;
  const desc = document.getElementById('audioDesc').value;
  const btn = document.getElementById('generateBtn');
  btn.disabled = true;
  btn.innerHTML = '<span class="loader"></span> AI Generating Prompts...';

  const styleNames = { dragonball: 'Dragon Ball Z', jujutsu: 'Jujutsu Kaisen', naruto: 'Naruto', onepiece: 'One Piece', attack: 'Attack on Titan', demon: 'Demon Slayer', ghibli: 'Studio Ghibli' };
  const modeNames = { singer: 'anime character singing', mv: 'anime music video', story: 'anime story scene', battle: 'anime battle scene' };

  try {
    const response = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'x-api-key': ANTHROPIC_KEY, 'anthropic-version': '2023-06-01', 'anthropic-dangerous-direct-browser-access': 'true' },
      body: JSON.stringify({
        model: 'claude-sonnet-4-6',
        max_tokens: 2000,
        messages: [{ role: 'user', content: `Generate 7 unique anime video prompts for Hailuo AI video generator. Style: ${styleNames[style]}. Mode: ${modeNames[mode]}. Audio description: ${desc || 'energetic music track'}. Each prompt should be for a different day with different characters, backgrounds, camera angles, lighting, and moods. Make each prompt 2-3 sentences, highly detailed and cinematic. Format as JSON array with objects containing: day (1-7), dayName (Monday-Sunday), prompt (the full prompt text), style_tags (array of 3-4 keywords). Return ONLY valid JSON, no other text.` }]
      })
    });
    const data = await response.json();
    let prompts;
    try {
      const text = data.content?.[0]?.text || '[]';
      const clean = text.replace(/```json|```/g, '').trim();
      prompts = JSON.parse(clean);
    } catch(e) {
      prompts = generateFallbackPrompts(styleNames[style], modeNames[mode]);
    }
    displayPrompts(prompts);
  } catch(e) {
    displayPrompts(generateFallbackPrompts(styleNames[style], modeNames[mode]));
  }
  btn.disabled = false;
  btn.textContent = '🤖 Generate 7 Day Prompts with AI';
}

function generateFallbackPrompts(style, mode) {
  const days = ['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday','Sunday'];
  const scenes = ['neon-lit city rooftop','cherry blossom forest','ancient temple courtyard','futuristic stadium','mountain peak at sunset','underwater crystal palace','floating sky islands'];
  return days.map((day, i) => ({
    day: i + 1, dayName: day,
    prompt: `${style} style anime character performing ${mode} in a ${scenes[i]}, cinematic camera movement, dramatic lighting, high energy performance, 4K quality animation, smooth lip sync to beat.`,
    style_tags: [style.split(' ')[0], 'cinematic', '4K', 'lip-sync']
  }));
}

function displayPrompts(prompts) {
  const result = document.getElementById('promptsResult');
  const list = document.getElementById('promptList');
  result.style.display = 'block';
  list.innerHTML = prompts.map(p => `
    <div class="prompt-item">
      <div class="prompt-day">Day ${p.day} — ${p.dayName}</div>
      <div class="prompt-text">${p.prompt}</div>
      <div class="prompt-style">${(p.style_tags || []).map(t => `<span class="style-tag">${t}</span>`).join('')}</div>
      <button class="btn btn-cyan" style="font-size:11px;padding:7px 14px;width:100%" onclick="copyPrompt(this, \`${p.prompt.replace(/`/g,"'")}\`)">📋 Copy Prompt</button>
    </div>`).join('');
  result.scrollIntoView({ behavior: 'smooth', block: 'start' });
}

function copyPrompt(btn, text) {
  navigator.clipboard.writeText(text).then(() => {
    btn.textContent = '✅ Copied!';
    btn.style.background = 'rgba(0,255,136,0.1)';
    btn.style.color = 'var(--green)';
    btn.style.borderColor = 'rgba(0,255,136,0.3)';
    setTimeout(() => { btn.textContent = '📋 Copy Prompt'; btn.style.background = ''; btn.style.color = ''; btn.style.borderColor = ''; }, 2000);
  });
}

// ── VIDEO UPLOAD ──
async function handleVideoUpload(event) {
  const file = event.target.files[0];
  if (!file || !currentUser) return;
  const progress = document.getElementById('videoProgress');
  const fill = document.getElementById('videoProgressFill');
  const label = document.getElementById('videoProgressLabel');
  progress.style.display = 'block';
  label.textContent = 'Uploading video...';
  fill.style.width = '30%';
  const fileName = `videos/${currentUser.id}/${Date.now()}_${file.name}`;
  const { error } = await sb.storage.from('audio-files').upload(fileName, file);
  if (error) { showToast('Upload failed: ' + error.message, 'error'); progress.style.display = 'none'; return; }
  fill.style.width = '100%';
  label.textContent = '✅ Video uploaded! Make.com will auto-post it.';
  setTimeout(() => progress.style.display = 'none', 3000);
  showToast('✅ Video saved! Make.com will post it automatically.', 'success');
  loadVideoList();
  loadStats();
}

async function loadVideoList() {
  if (!currentUser) return;
  const { data } = await sb.storage.from('audio-files').list(`videos/${currentUser.id}`);
  const list = document.getElementById('videoList');
  const count = document.getElementById('videoCount');
  if (!data || data.length === 0) { list.innerHTML = '<div style="text-align:center;padding:30px;color:var(--text-dim);font-size:13px;grid-column:1/-1">No videos yet. Generate from Hailuo AI and upload here!</div>'; count.textContent = '0 videos'; return; }
  count.textContent = data.length + ' video' + (data.length !== 1 ? 's' : '');
  list.innerHTML = data.map(v => `
    <div class="video-card">
      <div class="video-thumb">🎌<span class="video-status vs-ready">Ready</span></div>
      <div class="video-info">
        <div class="video-name">${v.name}</div>
        <div class="video-meta">${new Date(v.created_at).toLocaleDateString()}</div>
        <button class="btn btn-green btn-full" style="font-size:11px;padding:6px">📤 Will Auto Post</button>
      </div>
    </div>`).join('');
}

// ── CAMPAIGN ──
async function createCampaign() {
  const name = document.getElementById('campName').value;
  const mode = document.getElementById('campMode').value;
  const videoTime = document.getElementById('campVideoTime').value;
  const shortTime = document.getElementById('campShortTime').value;
  if (!name) return showToast('Please enter a campaign name', 'error');
  if (!currentUser) return;
  const startDate = new Date();
  const endDate = new Date();
  endDate.setDate(endDate.getDate() + 7);
  const { error } = await sb.from('campaigns').insert({ user_id: currentUser.id, anime_mode: mode, start_date: startDate.toISOString().split('T')[0], end_date: endDate.toISOString().split('T')[0], status: 'active' });
  if (error) { showToast('Error: ' + error.message, 'error'); return; }
  showToast('✅ Campaign created and saved!', 'success');
  renderCalendar(videoTime, shortTime);
  loadCampaignList();
  loadStats();
}

function renderCalendar(videoTime, shortTime) {
  const calendar = document.getElementById('campaignCalendar');
  const grid = document.getElementById('daysGrid');
  calendar.style.display = 'block';
  const days = ['Mon','Tue','Wed','Thu','Fri','Sat','Sun'];
  const today = new Date().getDay();
  grid.innerHTML = days.map((day, i) => {
    const isToday = (i + 1) % 7 === today % 7;
    return `<div class="day-col ${isToday ? 'today' : ''}">
      <div class="day-name">${day}</div>
      <div class="day-num">${i + 1}</div>
      <div class="day-pill ${isToday ? 'pill-video' : 'pill-done'}">Video</div>
      <div class="day-pill ${isToday ? 'pill-short' : 'pill-done'}">Short</div>
      <div style="font-size:9px;color:var(--text-dim);margin-top:4px">${videoTime}</div>
    </div>`;
  }).join('');
}

async function loadCampaignList() {
  if (!currentUser) return;
  const { data } = await sb.from('campaigns').select('*').eq('user_id', currentUser.id).order('created_at', { ascending: false });
  const list = document.getElementById('campaignList');
  if (!data || data.length === 0) { list.innerHTML = '<div style="text-align:center;padding:20px;color:var(--text-dim);font-size:13px">No campaigns yet</div>'; return; }
  list.innerHTML = data.map(c => `
    <div class="audio-item">
      <div class="audio-item-icon">📅</div>
      <div class="audio-item-info">
        <div class="audio-item-name">${c.anime_mode} Campaign</div>
        <div class="audio-item-meta">${c.start_date} → ${c.end_date} · ${c.status}</div>
      </div>
      <span class="badge ${c.status === 'active' ? 'badge-green' : 'badge-gold'}">${c.status}</span>
    </div>`).join('');
}

// ── TOAST ──
function showToast(msg, type = 'info') {
  const toast = document.getElementById('toast');
  toast.textContent = msg;
  toast.className = 'toast ' + type + ' show';
  setTimeout(() => toast.classList.remove('show'), 3500);
}

// ── DRAG DROP ──
['audioUploadZone','videoUploadZone'].forEach(id => {
  const zone = document.getElementById(id);
  if (!zone) return;
  zone.addEventListener('dragover', e => { e.preventDefault(); zone.classList.add('drag'); });
  zone.addEventListener('dragleave', () => zone.classList.remove('drag'));
  zone.addEventListener('drop', e => { e.preventDefault(); zone.classList.remove('drag'); });
});
</script>
</body>
</html>
