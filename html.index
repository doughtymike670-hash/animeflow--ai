            <div class="card-header"><div class="card-title">📋 How It Works</div></div>
            <div style="display:flex;flex-direction:column;gap:10px">
              <div style="display:flex;gap:10px;align-items:flex-start">
                <div style="width:22px;height:22px;border-radius:50%;background:rgba(139,61,255,0.2);color:var(--purple);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;flex-shrink:0">1</div>
                <div style="font-size:12px;color:var(--text-mid)">Upload audio → AI enhances it to studio quality</div>
              </div>
              <div style="display:flex;gap:10px;align-items:flex-start">
                <div style="width:22px;height:22px;border-radius:50%;background:rgba(255,45,120,0.15);color:var(--pink);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;flex-shrink:0">2</div>
                <div style="font-size:12px;color:var(--text-mid)">Get 7 unique anime prompts → paste into Hailuo AI</div>
              </div>
              <div style="display:flex;gap:10px;align-items:flex-start">
                <div style="width:22px;height:22px;border-radius:50%;background:rgba(0,229,255,0.1);color:var(--cyan);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;flex-shrink:0">3</div>
                <div style="font-size:12px;color:var(--text-mid)">Download video from Hailuo → upload here</div>
              </div>
              <div style="display:flex;gap:10px;align-items:flex-start">
                <div style="width:22px;height:22px;border-radius:50%;background:rgba(0,255,136,0.1);color:var(--green);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;flex-shrink:0">4</div>
                <div style="font-size:12px;color:var(--text-mid)">Make.com auto posts to all platforms at scheduled time</div>
              </div>
            </div>
