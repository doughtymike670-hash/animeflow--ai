      <!-- AUDIO PAGE -->
      <div class="page" id="page-audio">
        <div class="card" style="margin-bottom:16px">
          <div class="card-header"><div class="card-title">🎵 Upload Audio</div><span class="badge badge-purple">AI Enhanced</span></div>
          <div class="upload-zone" id="audioUploadZone">
            <input type="file" id="audioFileInput" accept="audio/*" onchange="handleAudioUpload(event)">
            <div class="upload-icon">🎵</div>
            <h3>Drop your audio here</h3>
            <p>MP3, WAV, OGG, FLAC, M4A supported</p>
          </div>
          <div class="progress-wrap" id="audioProgress">
            <div class="progress-label" id="audioProgressLabel">Uploading...</div>
            <div class="progress-bar-bg"><div class="progress-bar-fill" id="audioProgressFill"></div></div>
          </div>
          <div class="ai-processing" id="aiProcessing">
            <div class="loader" style="margin:0 auto 12px"></div>
            <h3>🤖 AI Analyzing Your Audio</h3>
            <p>Claude is analyzing your track and determining the best enhancement settings...</p>
            <div id="aiAnalysisResult" style="text-align:left;background:var(--card);border-radius:8px;padding:12px;margin-top:10px;font-size:11px;color:var(--text-mid);line-height:1.7;display:none"></div>
          </div>
        </div>
        <div class="card">
          <div class="card-header"><div class="card-title">🎧 My Audio Tracks</div><span class="badge badge-green" id="audioCount">0 tracks</span></div>
