      <div class="page" id="page-prompts">
        <div class="card" style="margin-bottom:16px">
          <div class="card-header"><div class="card-title">🎌 Generate Anime Prompts</div><span class="badge badge-cyan">AI Powered</span></div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:16px">
            <div class="form-group" style="margin:0">
              <label class="form-label">Anime Style</label>
              <select class="select-input" id="animeStyle">
                <option value="dragonball">Dragon Ball Z</option>
                <option value="jujutsu">Jujutsu Kaisen</option>
                <option value="naruto">Naruto</option>
                <option value="onepiece">One Piece</option>
                <option value="attack">Attack on Titan</option>
